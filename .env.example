# PostgreSQL Connection
# Example: postgresql+psycopg://user:password@host:5432/database
# For Supabase: postgresql+psycopg://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
POSTGRES_URL=postgresql+psycopg://user:password@host:5432/database

# Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
